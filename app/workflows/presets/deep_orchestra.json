{
  "id": "deep_orchestra",
  "name": "Deep Orchestra",
  "description": "Orchestrator, workers, report, and decision collaborate in the selected mode for deeper research or analysis.",
  "modes": ["chat", "code", "agentic"],
  "execution": "loop",
  "max_iterations": 2,
  "nodes": [
    {
      "id": "orchestrator",
      "type": "role",
      "role": "orchestrator",
      "title": "Plan",
      "output": "plan",
      "max_items": 3,
      "expects_json": true
    },
    {
      "id": "workers",
      "type": "worker_pool",
      "role": "worker",
      "title": "Workers",
      "input": "plan.work_items",
      "output": "worker_reports",
      "worker_instances": 2,
      "max_parallel": 2,
      "max_items": 3
    },
    {
      "id": "report",
      "type": "report",
      "role": "reviewer",
      "title": "Report",
      "input": ["plan", "worker_reports"],
      "output": "review",
      "expects_json": true
    },
    {
      "id": "decision",
      "type": "decision",
      "role": "judge",
      "title": "Decision",
      "input": ["plan", "worker_reports", "review"],
      "output": "decision",
      "expects_json": true,
      "config": {
        "branches": [
          {"label": "Done", "when": "decision.status == 'done'"},
          {"label": "Retry", "when": "decision.status == 'retry'"},
          {"label": "Needs user", "when": "decision.status == 'needs_user'"}
        ]
      }
    },
    {
      "id": "ask_user",
      "type": "pause",
      "title": "Ask User",
      "input": ["decision"],
      "output": "pause"
    },
    {
      "id": "answer",
      "type": "answer",
      "role": "orchestrator",
      "title": "Answer",
      "input": ["plan", "worker_reports", "review", "decision"],
      "output": "final_answer"
    }
  ],
  "edges": [
    {"from": "orchestrator", "to": "workers"},
    {"from": "workers", "to": "report"},
    {"from": "report", "to": "decision"},
    {"from": "decision", "to": "orchestrator", "when": "decision.status == 'retry'"},
    {"from": "decision", "to": "answer", "when": "decision.status == 'done'"},
    {"from": "decision", "to": "ask_user", "when": "decision.status == 'needs_user'"},
    {"from": "ask_user", "to": "orchestrator"}
  ]
}
